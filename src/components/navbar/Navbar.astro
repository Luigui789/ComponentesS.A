---
import Button from "../ui/Button.astro";
import Container from "../ui/Container.astro";
import MegaMenuSolutions from "./MegaMenuSolutions.astro";
import MegaMenuIndustries from "./MegaMenuIndustries.astro";
---

<header
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white border-b border-border/50 shadow-sm"
>
    <Container>
        <div class="flex items-center justify-between h-20">
            <!-- Logo -->
            <a href="/" class="flex flex-col justify-center">
                <span
                    class="text-2xl font-heading font-black tracking-tighter text-primary-500 leading-none"
                >
                    Componentes S.A.
                </span>
            </a>

            <!-- Desktop Nav -->
            <nav class="hidden md:flex items-center gap-8">
                <a
                    href="/"
                    class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
                    >Inicio</a
                >

                <div class="relative group h-20 flex items-center">
                    <button
                        class="text-sm font-medium text-muted-foreground group-hover:text-foreground transition-colors flex items-center gap-1"
                    >
                        Soluciones
                        <svg
                            class="w-4 h-4 transition-transform group-hover:rotate-180"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </button>
                    <MegaMenuSolutions />
                </div>

                <div class="relative group h-20 flex items-center">
                    <button
                        class="text-sm font-medium text-muted-foreground group-hover:text-foreground transition-colors flex items-center gap-1"
                    >
                        Industrias
                        <svg
                            class="w-4 h-4 transition-transform group-hover:rotate-180"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </button>
                    <MegaMenuIndustries />
                </div>

                <a
                    href="/servicios"
                    class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
                    >Servicios</a
                >
            </nav>

            <!-- CTA -->
            <div class="hidden md:flex items-center gap-4">
                <a
                    href="tel:+50212345678"
                    class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
                >
                    Ventas: +502 1234 5678
                </a>
                <Button href="/contacto" variant="primary" size="sm">
                    Cotizar Ahora
                </Button>
            </div>

            <!-- Mobile menu button -->
            <button class="md:hidden p-2 text-foreground" aria-label="Menu">
                <svg
                    class="w-6 h-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </Container>
</header>
