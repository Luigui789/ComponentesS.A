---
import Button from "../ui/Button.astro";
import Container from "../ui/Container.astro";
import MegaMenuSolutions from "./MegaMenuSolutions.astro";
import MegaMenuIndustries from "./MegaMenuIndustries.astro";
---

<header
    class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white border-b border-border/50 shadow-sm"
>
    <Container>
        <div class="flex items-center justify-between h-20">
            <!-- Logo -->
            <a href="/" class="flex flex-col justify-center">
                <span
                    class="text-2xl font-heading font-black tracking-tighter text-primary-500 leading-none"
                >
                    Componentes S.A.
                </span>
            </a>

            <!-- Desktop Nav -->
            <nav class="hidden md:flex items-center gap-8">
                <a
                    href="/"
                    class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
                    >Inicio</a
                >

                <div class="relative group h-20 flex items-center">
                    <button
                        class="text-sm font-medium text-muted-foreground group-hover:text-foreground transition-colors flex items-center gap-1"
                    >
                        Soluciones
                        <svg
                            class="w-4 h-4 transition-transform group-hover:rotate-180"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </button>
                    <MegaMenuSolutions />
                </div>

                <div class="relative group h-20 flex items-center">
                    <button
                        class="text-sm font-medium text-muted-foreground group-hover:text-foreground transition-colors flex items-center gap-1"
                    >
                        Industrias
                        <svg
                            class="w-4 h-4 transition-transform group-hover:rotate-180"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 9l-7 7-7-7"></path></svg
                        >
                    </button>
                    <MegaMenuIndustries />
                </div>

                <a
                    href="/servicios"
                    class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
                    >Servicios</a
                >
            </nav>

            <!-- CTA -->
            <div class="hidden md:flex items-center gap-4">
                <a
                    href="tel:+50522707918"
                    class="text-sm font-medium text-muted-foreground hover:text-foreground transition-colors"
                >
                    Ventas: +505 2270-7918
                </a>
                <Button href="/contacto" variant="primary" size="sm">
                    Cotizar Ahora
                </Button>
            </div>

            <!-- Mobile menu button -->
            <button
                id="mobile-menu-btn"
                class="md:hidden p-2 text-foreground"
                aria-label="Menu"
                aria-expanded="false"
            >
                <svg
                    id="icon-open"
                    class="w-6 h-6 block"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
                <svg
                    id="icon-close"
                    class="w-6 h-6 hidden"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>
    </Container>

    <!-- Mobile Menu Overlay -->
    <div
        id="mobile-menu"
        class="fixed inset-x-0 top-20 bottom-0 bg-background z-40 overflow-y-auto border-t border-border/50 opacity-0 pointer-events-none -translate-y-4 transition-all duration-300 ease-in-out"
    >
        <div class="p-6 flex flex-col gap-6 w-full max-w-md mx-auto h-full">
            <a
                href="/"
                class="text-lg font-bold text-foreground py-2 border-b border-border/50"
                >Inicio</a
            >

            <div class="flex flex-col gap-3">
                <span
                    class="text-xs font-bold text-muted-foreground uppercase tracking-wider mb-2"
                    >Soluciones</span
                >
                <a
                    href="/soluciones/pos"
                    class="text-base font-medium text-foreground py-1 flex items-center gap-2"
                >
                    <span class="w-1.5 h-1.5 rounded-full bg-primary-500"
                    ></span> Oracle Simphony POS
                </a>
                <a
                    href="/soluciones/facturacion"
                    class="text-base font-medium text-foreground py-1 flex items-center gap-2"
                >
                    <span class="w-1.5 h-1.5 rounded-full bg-primary-500"
                    ></span> Safiro FEL
                </a>
                <a
                    href="/soluciones/hotelero"
                    class="text-base font-medium text-foreground py-1 flex items-center gap-2"
                >
                    <span class="w-1.5 h-1.5 rounded-full bg-primary-500"
                    ></span> Safiro Hotelero
                </a>
                <a
                    href="/soluciones/hardware"
                    class="text-base font-medium text-foreground py-1 flex items-center gap-2"
                >
                    <span class="w-1.5 h-1.5 rounded-full bg-primary-500"
                    ></span> Hardware & Equipos
                </a>
            </div>

            <div class="flex flex-col gap-3">
                <span
                    class="text-xs font-bold text-muted-foreground uppercase tracking-wider mb-2 mt-4"
                    >Industrias</span
                >
                <a
                    href="/industrias/restaurantes"
                    class="text-base font-medium text-foreground py-1 flex items-center gap-2"
                >
                    <span class="w-1.5 h-1.5 rounded-full bg-secondary-500"
                    ></span> Restaurantes & Bares
                </a>
                <a
                    href="/industrias/hoteles"
                    class="text-base font-medium text-foreground py-1 flex items-center gap-2"
                >
                    <span class="w-1.5 h-1.5 rounded-full bg-secondary-500"
                    ></span> Hoteles & Resorts
                </a>
                <a
                    href="/industrias/retail"
                    class="text-base font-medium text-foreground py-1 flex items-center gap-2"
                >
                    <span class="w-1.5 h-1.5 rounded-full bg-secondary-500"
                    ></span> Retail Comercial
                </a>
                <a
                    href="/industrias/franquicias"
                    class="text-base font-medium text-foreground py-1 flex items-center gap-2"
                >
                    <span class="w-1.5 h-1.5 rounded-full bg-secondary-500"
                    ></span> Cadenas de Franquicias
                </a>
            </div>

            <a
                href="/servicios"
                class="text-lg font-bold text-foreground py-2 border-b border-t border-border/50 mt-4"
                >Servicios</a
            >
            <a
                href="/contacto"
                class="text-lg font-bold text-foreground py-2 border-b border-border/50"
                >Contacto</a
            >

            <div class="mt-auto pt-8">
                <a
                    href="tel:+50212345678"
                    class="text-lg font-bold text-primary-600 mb-4 block text-center"
                    >Ventas: +502 1234 5678</a
                >
                <Button
                    href="/contacto"
                    variant="primary"
                    className="w-full justify-center">Cotizar Ahora</Button
                >
            </div>

            <!-- Padding at the bottom for scroll space -->
            <div class="h-8"></div>
        </div>
    </div>
</header>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const btn = document.getElementById("mobile-menu-btn");
        const menu = document.getElementById("mobile-menu");
        const iconOpen = document.getElementById("icon-open");
        const iconClose = document.getElementById("icon-close");

        if (btn && menu && iconOpen && iconClose) {
            btn.addEventListener("click", () => {
                const isExpanded = btn.getAttribute("aria-expanded") === "true";
                btn.setAttribute("aria-expanded", String(!isExpanded));

                menu.classList.toggle("opacity-0");
                menu.classList.toggle("pointer-events-none");
                menu.classList.toggle("-translate-y-4");
                menu.classList.toggle("opacity-100");
                menu.classList.toggle("pointer-events-auto");
                menu.classList.toggle("translate-y-0");

                iconOpen.classList.toggle("hidden");
                iconOpen.classList.toggle("block");

                iconClose.classList.toggle("hidden");
                iconClose.classList.toggle("block");

                if (!isExpanded) {
                    document.body.style.overflow = "hidden";
                } else {
                    document.body.style.overflow = "";
                }
            });
        }
    });

    // Handle view transitions for Astro
    document.addEventListener("astro:page-load", () => {
        const btn = document.getElementById("mobile-menu-btn");
        const menu = document.getElementById("mobile-menu");
        const iconOpen = document.getElementById("icon-open");
        const iconClose = document.getElementById("icon-close");

        if (btn && menu && iconOpen && iconClose) {
            // Ensure menu is closed on new page load
            menu.classList.add(
                "opacity-0",
                "pointer-events-none",
                "-translate-y-4",
            );
            menu.classList.remove(
                "opacity-100",
                "pointer-events-auto",
                "translate-y-0",
            );
            iconOpen.classList.remove("hidden");
            iconOpen.classList.add("block");
            iconClose.classList.add("hidden");
            iconClose.classList.remove("block");
            document.body.style.overflow = "";
            btn.setAttribute("aria-expanded", "false");

            btn.addEventListener("click", () => {
                const isExpanded = btn.getAttribute("aria-expanded") === "true";
                btn.setAttribute("aria-expanded", String(!isExpanded));

                menu.classList.toggle("opacity-0");
                menu.classList.toggle("pointer-events-none");
                menu.classList.toggle("-translate-y-4");
                menu.classList.toggle("opacity-100");
                menu.classList.toggle("pointer-events-auto");
                menu.classList.toggle("translate-y-0");

                iconOpen.classList.toggle("hidden");
                iconOpen.classList.toggle("block");

                iconClose.classList.toggle("hidden");
                iconClose.classList.toggle("block");

                if (!isExpanded) {
                    document.body.style.overflow = "hidden";
                } else {
                    document.body.style.overflow = "";
                }
            });
        }
    });
</script>
