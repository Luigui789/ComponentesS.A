---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
---

<section
    class="py-24 bg-primary-900 relative overflow-hidden border-t border-primary-800"
>
    <!-- Subtle Corporate Grid Background -->
    <div class="absolute inset-0 z-0">
        <svg
            class="absolute w-full h-full opacity-10"
            xmlns="http://www.w3.org/2000/svg"
        >
            <defs>
                <pattern
                    id="grid-pattern"
                    x="0"
                    y="0"
                    width="40"
                    height="40"
                    patternUnits="userSpaceOnUse"
                >
                    <path
                        d="M 40 0 L 0 0 0 40"
                        fill="none"
                        stroke="white"
                        stroke-width="1"></path>
                </pattern>
            </defs>
            <rect width="100%" height="100%" fill="url(#grid-pattern)"></rect>
        </svg>
    </div>

    <!-- Solid architectural accent -->
    <div
        class="absolute top-0 right-0 w-1/3 h-full bg-primary-800/30 transform skew-x-12 origin-top-right -z-10"
    >
    </div>

    <Container className="relative z-10">
        <div class="max-w-4xl mx-auto text-center">
            <h2
                class="text-4xl lg:text-5xl font-heading font-black text-white mb-6 leading-tight"
            >
                El Futuro de tu Operación <br />
                <span class="text-secondary-400">Comienza Aquí</span>
            </h2>
            <p
                class="text-lg text-primary-100 mb-10 max-w-2xl mx-auto leading-relaxed font-medium"
            >
                Agenda una consulta técnica con nuestros especialistas y
                descubre cómo nuestra infraestructura transforma el rendimiento
                operativo financiero de tu empresa.
            </p>

            <div
                class="flex flex-col sm:flex-row items-center justify-center gap-4"
            >
                <Button
                    href="/contacto"
                    variant="primary"
                    size="lg"
                    className="w-full sm:w-auto text-lg px-8 rounded-none bg-secondary-500 hover:bg-secondary-600 text-white border-secondary-500"
                >
                    Agendar Evaluación Técnica
                </Button>
                <Button
                    href="/servicios"
                    variant="outline"
                    size="lg"
                    className="w-full sm:w-auto text-lg px-8 rounded-none border-primary-400 text-white hover:bg-primary-800"
                >
                    Explorar Servicios
                </Button>
            </div>

            <div
                class="mt-16 pt-12 border-t border-primary-700/50 opacity-80 relative"
            >
                <h4
                    class="text-primary-300 text-sm font-bold uppercase tracking-widest text-center w-full mb-8"
                >
                    Ecosistema Tecnológico Integrado
                </h4>

                <div
                    class="flex flex-col md:flex-row justify-center items-center gap-12 md:gap-24"
                >
                    <!-- Grupo Oracle -->
                    <div class="flex flex-col items-center gap-3">
                        <div
                            class="text-white font-black text-3xl tracking-tighter"
                        >
                            ORACLE
                        </div>
                        <div
                            class="flex flex-wrap justify-center items-center gap-2 text-primary-200 font-medium text-sm tracking-widest uppercase"
                        >
                            <span>Simphony Micros</span>
                            <span
                                class="w-1 h-1 md:w-1.5 md:h-1.5 rounded-full bg-primary-500 hidden sm:block"
                            ></span>
                            <span>Opera PMS</span>
                        </div>
                    </div>

                    <!-- Divisor -->
                    <div class="hidden md:block w-px h-16 bg-primary-700/50">
                    </div>

                    <!-- Grupo Safiro -->
                    <div class="flex flex-col items-center gap-3">
                        <div
                            class="text-secondary-400 font-black text-3xl tracking-tighter"
                        >
                            SAFIRO
                        </div>
                        <div
                            class="flex justify-center items-center gap-3 text-primary-200 font-medium text-sm tracking-widest uppercase"
                        >
                            <span>ERP Financiero Integral</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </Container>
</section>
