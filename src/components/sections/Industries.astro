---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";

const industries = [
    {
        name: "Restaurantes & Bares",
        desc: "Gestión de mesas, comandas móviles y control de materia prima exacto. Optimiza la rotación y el servicio al cliente con Simphony.",
        img: "https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
        href: "/industrias/restaurantes"
    },
    {
        name: "Hoteles & Resorts",
        desc: "Integración PMS, puntos de venta distribuidos en piscinas y restaurantes, y contabilidad centralizada con facturación unificada.",
        img: "https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
        href: "/industrias/hoteles"
    },
    {
        name: "Franquicias",
        desc: "Control multi-sucursal y estandarización de procesos. Métricas operativas consolidadas a nivel corporativo.",
        img: "https://images.unsplash.com/photo-1555396273-367ea4eb4db5?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80",
        href: "/industrias/franquicias"
    },
];
---

<section class="py-24 bg-card border-b border-border">
    <Container>
        <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16">
            <div class="max-w-2xl">
                <h2 class="text-primary-600 font-bold tracking-wide uppercase text-sm mb-3">Especialización Sectorial</h2>
                <h3 class="text-4xl font-heading font-black text-foreground">Soluciones Adaptadas a tu Industria</h3>
            </div>
            <Button href="/contacto" variant="outline" className="shrink-0">
                Consultar mi Industria
            </Button>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {industries.map(industry => (
                <a href={industry.href} class="group block relative h-96 overflow-hidden bg-muted border border-border">
                    <img 
                        src={industry.img} 
                        alt={industry.name} 
                        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                    />
                    <!-- Overlay gradient strictly for legibility -->
                    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent"></div>
                    
                    <div class="absolute bottom-0 left-0 p-8 w-full flex flex-col justify-end">
                        <h4 class="text-2xl font-bold text-white mb-3 flex items-center gap-2">
                            {industry.name}
                            <svg class="w-5 h-5 opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
                        </h4>
                        <p class="text-white/80 text-sm leading-relaxed mb-0 transform translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300">
                            {industry.desc}
                        </p>
                    </div>
                </a>
            ))}
        </div>
    </Container>
</section>
