---
import Container from "../ui/Container.astro";
import { Image } from "astro:assets";

import pharaos from "../../assets/clients/pharaos.webp";
import guacalito from "../../assets/clients/guacalito.webp";
import zacateLimon from "../../assets/clients/zacate-limon.webp";
import ranchoSantana from "../../assets/clients/rancho_santana.webp";
import intercontinental from "../../assets/clients/intercontinental.webp";
import marriott from "../../assets/clients/marriott.png";
import fourSeasons from "../../assets/clients/four-seasons.png";
import hyattPlace from "../../assets/clients/Hyatt-place.jpg";
import molinoCoffee from "../../assets/clients/molino-coffe.jpg";
import porterHouse from "../../assets/clients/porter-house.png";
import starbucks from "../../assets/clients/starbucks.png";
import burgerKing from "../../assets/clients/burger-king.png";

const clients = [
    {
        name: "Starbucks",
        logo: starbucks,
    },
    {
        name: "Burger King",
        logo: burgerKing,
    },
    {
        name: "Hotel Four Seasons",
        logo: fourSeasons,
    },
    {
        name: "Marriott",
        logo: marriott,
    },
    {
        name: "HYATT Place",
        logo: hyattPlace,
    },
    {
        name: "Intercontinental",
        logo: intercontinental,
    },
    {
        name: "Pharaos Casinos",
        logo: pharaos,
    },
    {
        name: "Molino Coffee",
        logo: molinoCoffee,
    },
    {
        name: "Guacalito Nicaragua",
        logo: guacalito,
    },
    {
        name: "Rancho Santana",
        logo: ranchoSantana,
    },
    {
        name: "Porter House",
        logo: porterHouse,
    },
    {
        name: "ZacateLimon",
        logo: zacateLimon,
    },
];
---

<section class="py-24 bg-card border-b border-border overflow-hidden">
    <Container>
        <div class="grid lg:grid-cols-12 gap-12 items-center">
            <div class="lg:col-span-4">
                <h2
                    class="text-3xl font-heading font-black text-foreground mb-4"
                >
                    Confianza que Trasciende
                </h2>
                <p class="text-muted-foreground mb-8">
                    Más de 27 años de experiencia implementando tecnología en el
                    sector corporativo y hospitalidad a nivel regional.
                </p>
                <div class="flex gap-8">
                    <div>
                        <p class="text-3xl font-bold text-primary-600 mb-1">
                            +27
                        </p>
                        <p
                            class="text-xs font-bold uppercase tracking-wider text-muted-foreground"
                        >
                            Años Exp.
                        </p>
                    </div>
                    <div>
                        <p class="text-3xl font-bold text-primary-600 mb-1">
                            300+
                        </p>
                        <p
                            class="text-xs font-bold uppercase tracking-wider text-muted-foreground"
                        >
                            Clientes Activos
                        </p>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-8 overflow-hidden relative">
                <!-- Fog overlays for smooth scrolling effect -->
                <div
                    class="absolute inset-y-0 left-0 w-20 bg-gradient-to-r from-card to-transparent z-10 pointer-events-none"
                >
                </div>
                <div
                    class="absolute inset-y-0 right-0 w-20 bg-gradient-to-l from-card to-transparent z-10 pointer-events-none"
                >
                </div>

                <div
                    class="flex items-center gap-14 opacity-60 grayscale hover:grayscale-0 transition-all duration-500 animate-scroll hover:opacity-100 cursor-pointer"
                >
                    {
                        clients.map((client) => (
                            <div class="flex-shrink-0 w-32 h-20 flex items-center justify-center">
                                <Image
                                    src={client.logo}
                                    alt={client.name}
                                    class="max-w-[120px] max-h-[60px] object-contain"
                                    title={client.name}
                                />
                            </div>
                        ))
                    }
                    {/* Duplicate for infinite effect */}
                    {
                        clients.map((client) => (
                            <div class="flex-shrink-0 w-32 h-20 flex items-center justify-center">
                                <Image
                                    src={client.logo}
                                    alt={client.name}
                                    class="max-w-[120px] max-h-[60px] object-contain"
                                    title={client.name}
                                />
                            </div>
                        ))
                    }
                </div>
            </div>
        </div>
    </Container>
</section>

<style>
    .animate-scroll {
        display: flex;
        width: max-content;
        animation: scroll 20s linear infinite;
    }

    /* Pause animation on hover for better user experience */
    .animate-scroll:hover {
        animation-play-state: paused;
    }

    @keyframes scroll {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(-50%);
        }
    }
</style>
