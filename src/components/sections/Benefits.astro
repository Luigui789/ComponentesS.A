---
import Container from "../ui/Container.astro";

const benefits = [
    {
        title: "Terminales WS5A de Alta Gama",
        description:
            "Hardware robusto de Oracle MICROS diseñado para el alto tráfico. Múltiples puertos de conectividad aseguran que todos tus periféricos funcionen sin interrupciones.",
        icon: `<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>`,
    },
    {
        title: "Impresoras y Periféricos",
        description:
            "Integración nativa e impecable con impresoras de tickets Micros, garantizando una facturación ágil y confiable en el piso de venta o cocina.",
        icon: `<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg>`,
    },
    {
        title: "Outsourcing Contable Safiro",
        description:
            "Si prefieres que expertos administren el sistema por ti, ofrecemos servicios de outsourcing utilizando la plataforma Safiro.",
        icon: `<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    },
    {
        title: "Asesoría en Sistemas Integral",
        description:
            "Realizamos una evaluación técnica profunda de tu negocio de forma previa para asegurar que Safiro o Simphony se adapten al 100% a tus necesidades específicas.",
        icon: `<svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`,
    },
];
---

<section class="py-24 bg-card border-b border-border">
    <Container>
        <div class="grid lg:grid-cols-2 gap-16 items-center">
            <div>
                <h2
                    class="text-primary-600 font-bold tracking-wide uppercase text-sm mb-3"
                >
                    Beneficios Clave
                </h2>
                <h3
                    class="text-4xl lg:text-5xl font-heading font-black text-foreground mb-6 leading-tight"
                >
                    Diseñado para Escalar tu Negocio de Forma Inteligente
                </h3>
                <p
                    class="text-lg text-muted-foreground mb-10 leading-relaxed max-w-lg"
                >
                    No solo vendemos software; proporcionamos el motor
                    tecnológico que impulsa el crecimiento operativo y
                    financiero de restaurantes, hoteles y negocios de retail.
                </p>

                <div class="space-y-8">
                    {
                        benefits.map((benefit) => (
                            <div class="flex gap-4">
                                <div class="flex-shrink-0 mt-1">
                                    <div class="w-12 h-12 rounded border border-border bg-muted flex items-center justify-center">
                                        <div
                                            class="text-primary-600 w-6 h-6 flex items-center justify-center [&>svg]:w-full [&>svg]:h-full"
                                            set:html={benefit.icon.replace(
                                                "text-white",
                                                "currentColor",
                                            )}
                                        />
                                    </div>
                                </div>
                                <div>
                                    <h4 class="text-xl font-bold text-foreground mb-2">
                                        {benefit.title}
                                    </h4>
                                    <p class="text-muted-foreground leading-relaxed">
                                        {benefit.description}
                                    </p>
                                </div>
                            </div>
                        ))
                    }
                </div>
            </div>

            <div
                class="relative w-full h-full min-h-[500px] border border-border bg-muted p-4 lg:p-8 flex items-center justify-center"
            >
                <img
                    src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80"
                    alt="Dashboard de análisis"
                    class="w-full h-full object-cover shadow border border-border"
                />
            </div>
        </div>
    </Container>
</section>
