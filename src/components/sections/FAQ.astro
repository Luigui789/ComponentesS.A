---
import Container from "../ui/Container.astro";

const faqs = [
    {
        question: "¿Cuánto cuesta implementar Oracle Simphony o Safiro ERP?",
        answer: "El costo varía según el tamaño de tu operación, el número de terminales y los módulos que necesitás. Ofrecemos planes desde instalaciones para un solo local hasta cadenas con múltiples sucursales. Contáctanos para una cotización personalizada sin compromiso.",
    },
    {
        question: "¿Mis empleados necesitan ser técnicos para usar el sistema?",
        answer: "Para nada. Oracle Simphony está diseñado para que cualquier mesero, cajero o gerente lo aprenda en pocas horas. Incluimos capacitación completa para todo tu personal como parte de la implementación.",
    },
    {
        question: "¿Qué pasa si el sistema falla en medio del servicio?",
        answer: "Oracle Simphony funciona en la nube pero también tiene modo offline: si se cae el internet, seguís tomando pedidos y procesando pagos con normalidad. Cuando vuelve la conexión, todo se sincroniza automáticamente. Además, tenemos soporte técnico disponible para emergencias.",
    },
    {
        question:
            "¿Puedo ver mis ventas desde el celular cuando no estoy en el local?",
        answer: "Sí, Oracle Simphony incluye la app InMotion para gerentes que te permite ver ventas en tiempo real, alertas de operación, comparativos por turno y mucho más desde tu teléfono, estés donde estés.",
    },
    {
        question: "¿Cuánto tiempo tarda la instalación y configuración?",
        answer: "Para un restaurante o hotel independiente, entre 1 y 4 semanas. Siempre y cuando se tenga la información completa para la implementación. Para cadenas con múltiples puntos de venta, desarrollamos un cronograma por fases.",
    },
    {
        question: "¿Puedo solicitar una demo antes de decidir?",
        answer: "¡Claro que sí! Te hacemos una demostración personalizada del sistema según tu tipo de negocio, sin costo y sin compromiso. Solo contáctanos y coordinamos una visita o videollamada a la hora que te convenga.",
    },
];
---

<section class="py-24 bg-background">
    <Container>
        <div class="grid lg:grid-cols-12 gap-12">
            <div class="lg:col-span-5">
                <h2
                    class="text-primary-600 font-bold tracking-wide uppercase text-sm mb-3"
                >
                    Soporte y Dudas
                </h2>
                <h3
                    class="text-4xl font-heading font-bold text-foreground mb-6"
                >
                    Preguntas Frecuentes
                </h3>
                <p class="text-lg text-muted-foreground mb-8">
                    Encuentra respuestas rápidas a las consultas más comunes que
                    tienen nuestros clientes sobre la implementación y
                    funcionamiento de nuestros sistemas.
                </p>
                <div
                    class="p-6 bg-primary-50 rounded-2xl border border-primary-100"
                >
                    <h4 class="font-bold text-lg mb-2 text-primary-900">
                        ¿Tienes otra pregunta?
                    </h4>
                    <p class="text-primary-700 mb-4">
                        Nuestro equipo de expertos está listo para asesorarte en
                        tu proyecto.
                    </p>
                    <a
                        href="/contacto"
                        class="inline-flex items-center text-primary-600 font-bold hover:text-primary-700 transition-colors"
                    >
                        Contactar Soporte
                        <svg
                            class="w-5 h-5 ml-2"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg
                        >
                    </a>
                </div>
            </div>

            <div class="lg:col-span-7">
                <div class="space-y-4">
                    {
                        faqs.map((faq, index) => (
                            <details class="group bg-card rounded-2xl border border-border shadow-sm [&_summary::-webkit-details-marker]:hidden">
                                <summary class="flex cursor-pointer items-center justify-between gap-1.5 p-6 text-foreground font-bold text-lg">
                                    {faq.question}

                                    <span class="relative h-5 w-5 shrink-0 text-primary-600">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="absolute inset-0 h-5 w-5 opacity-100 group-open:opacity-0 transition-opacity duration-200"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                            stroke-width="2"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                d="M12 4v16m8-8H4"
                                            />
                                        </svg>

                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            class="absolute inset-0 h-5 w-5 opacity-0 group-open:opacity-100 transition-opacity duration-200"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                            stroke-width="2"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                d="M20 12H4"
                                            />
                                        </svg>
                                    </span>
                                </summary>

                                <div class="px-6 pb-6 pt-0 text-muted-foreground leading-relaxed">
                                    <p>{faq.answer}</p>
                                </div>
                            </details>
                        ))
                    }
                </div>
            </div>
        </div>
    </Container>
</section>
