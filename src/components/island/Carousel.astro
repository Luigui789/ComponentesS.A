---
// Island: Carousel — COMPONENTE ÚNICO REUTILIZABLE
// Uso: <Carousel id="unico" slides={[{src, alt}]} height="h-[420px]" theme="light|dark" interval={4000} />
//
// Props:
//   id       — string único por página (evita conflictos si hay 2 carruseles)
//   slides   — array de { src: string, alt: string }
//   height   — clase Tailwind de alto (default: "h-[420px]")
//   theme    — "light" (botones oscuros) | "dark" (botones claros sobre fondos oscuros)
//   interval — ms entre slides (default: 4000)

interface Slide {
    src: string;
    alt: string;
}

interface Props {
    id: string;
    slides: Slide[];
    height?: string;
    theme?: "light" | "dark";
    interval?: number;
}

const {
    id,
    slides,
    height = "h-[420px]",
    theme = "light",
    interval = 4000,
} = Astro.props;

// Estilos de botones según tema
const btnBase =
    "absolute top-1/2 -translate-y-1/2 w-9 h-9 rounded-full flex items-center justify-center shadow-lg transition-all duration-200 hover:scale-110 z-10 focus:outline-none focus:ring-2";
const btnLight = `${btnBase} bg-white/80 hover:bg-white text-gray-800 focus:ring-primary-400`;
const btnDark = `${btnBase} bg-white/20 hover:bg-white/40 text-white   focus:ring-white/50 border border-white/10`;
const btnClass = theme === "dark" ? btnDark : btnLight;

// Estilos de dots según tema
const dotBase =
    "w-2 h-2 rounded-full transition-all duration-300 cursor-pointer focus:outline-none focus:ring-2 focus:ring-white/50";
const dotActive = theme === "dark" ? "bg-white" : "bg-primary-600";
const dotIdle = theme === "dark" ? "bg-white/40" : "bg-gray-300";
---

<div
    class={`relative w-full ${height}`}
    id={id}
    data-interval={interval}
    data-carousel-id={id}
>
    <!-- Slides -->
    <div
        class="relative w-full h-full overflow-hidden rounded-2xl shadow-2xl border border-white/10"
    >
        {
            slides.map((slide, i) => (
                <div
                    class="carousel-slide absolute inset-0 transition-opacity duration-700"
                    class:list={[
                        i === 0 ? "opacity-100 z-10" : "opacity-0 z-0",
                    ]}
                    data-index={i}
                    aria-hidden={i !== 0}
                >
                    <img
                        src={slide.src}
                        alt={slide.alt}
                        class="w-full h-full object-cover"
                        loading={i === 0 ? "eager" : "lazy"}
                        decoding={i === 0 ? "auto" : "async"}
                    />
                    <div class="absolute inset-0 bg-linear-to-t from-black/30 to-transparent pointer-events-none" />
                </div>
            ))
        }
    </div>

    <!-- Botón anterior -->
    <button
        type="button"
        class={`${btnClass} left-3`}
        data-action="prev"
        aria-label="Imagen anterior"
    >
        <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M15 19l-7-7 7-7"></path>
        </svg>
    </button>

    <!-- Botón siguiente -->
    <button
        type="button"
        class={`${btnClass} right-3`}
        data-action="next"
        aria-label="Imagen siguiente"
    >
        <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
        >
            <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2.5"
                d="M9 5l7 7-7 7"></path>
        </svg>
    </button>

    <!-- Dots -->
    <div
        class="absolute bottom-3 left-1/2 -translate-x-1/2 flex items-center gap-2 z-20"
    >
        {
            slides.map((_, i) => (
                <button
                    type="button"
                    class={`${dotBase} ${i === 0 ? dotActive : dotIdle}`}
                    data-dot={i}
                    aria-label={`Ir a imagen ${i + 1}`}
                />
            ))
        }
    </div>

    <!-- Contador 1/N -->
    <div
        class="absolute bottom-3 right-4 z-20 text-xs font-bold text-white/80 tabular-nums select-none"
    >
        <span data-current>1</span>/<span>{slides.length}</span>
    </div>
</div>

<script>
    // ── Island: Carousel ──────────────────────────────────────────────────────
    // Cada instancia se inicializa de forma independiente por su [data-carousel-id]
    document
        .querySelectorAll<HTMLElement>("[data-carousel-id]")
        .forEach((root) => {
            const intervalMs = Number(root.dataset.interval ?? 4000);

            const allSlides =
                root.querySelectorAll<HTMLElement>(".carousel-slide");
            const dots = root.querySelectorAll<HTMLElement>("[data-dot]");
            const counter = root.querySelector<HTMLElement>("[data-current]");
            const prevBtn = root.querySelector<HTMLButtonElement>(
                '[data-action="prev"]',
            );
            const nextBtn = root.querySelector<HTMLButtonElement>(
                '[data-action="next"]',
            );

            if (!allSlides.length) return;

            let current = 0;
            let timer: ReturnType<typeof setInterval>;

            function goTo(index: number) {
                // Ocultar slide actual
                allSlides[current].classList.replace(
                    "opacity-100",
                    "opacity-0",
                );
                allSlides[current].classList.replace("z-10", "z-0");
                allSlides[current].setAttribute("aria-hidden", "true");

                // Dot idle
                dots[current].style.opacity = "0.45";
                dots[current].style.transform = "scale(1)";

                current = (index + allSlides.length) % allSlides.length;

                // Mostrar slide nuevo
                allSlides[current].classList.replace(
                    "opacity-0",
                    "opacity-100",
                );
                allSlides[current].classList.replace("z-0", "z-10");
                allSlides[current].setAttribute("aria-hidden", "false");

                // Dot activo
                dots[current].style.opacity = "1";
                dots[current].style.transform = "scale(1.35)";

                if (counter) counter.textContent = String(current + 1);
            }

            function startTimer() {
                timer = setInterval(() => goTo(current + 1), intervalMs);
            }
            function resetTimer() {
                clearInterval(timer);
                startTimer();
            }

            // Inicializar estilos de dots
            dots.forEach((dot, i) => {
                dot.style.opacity = i === 0 ? "1" : "0.45";
                dot.style.transform = i === 0 ? "scale(1.35)" : "scale(1)";
                dot.addEventListener("click", () => {
                    goTo(Number(dot.dataset.dot));
                    resetTimer();
                });
            });

            prevBtn?.addEventListener("click", () => {
                goTo(current - 1);
                resetTimer();
            });
            nextBtn?.addEventListener("click", () => {
                goTo(current + 1);
                resetTimer();
            });

            // Pausar al hacer hover
            root.addEventListener("mouseenter", () => clearInterval(timer));
            root.addEventListener("mouseleave", startTimer);

            // Swipe táctil (mobile)
            let touchStartX = 0;
            root.addEventListener(
                "touchstart",
                (e) => {
                    touchStartX = e.touches[0].clientX;
                },
                { passive: true },
            );
            root.addEventListener(
                "touchend",
                (e) => {
                    const diff = touchStartX - e.changedTouches[0].clientX;
                    if (Math.abs(diff) > 40) {
                        goTo(diff > 0 ? current + 1 : current - 1);
                        resetTimer();
                    }
                },
                { passive: true },
            );

            startTimer();
        });
</script>
