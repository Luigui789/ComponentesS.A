---
import MainLayout from "../layouts/MainLayout.astro";
import Container from "../components/ui/Container.astro";
import CTA from "../components/sections/CTA.astro";
---

<MainLayout
    title="Sobre Nosotros"
    description="Conoce nuestra historia y propósito."
>
    <section class="pt-32 pb-24 bg-card border-b border-border">
        <Container className="text-center max-w-4xl">
            <h1 class="text-5xl md:text-6xl font-black mb-6 text-foreground">
                Componentes S.A.
            </h1>
            <p class="text-xl text-muted-foreground mx-auto">
                Somos pioneros en la digitalización y modernización del
                ecosistema HORECA y Retail en la región. Llevamos tecnología de
                clase mundial a negocios en crecimiento.
            </p>
        </Container>
    </section>
    <CTA />
</MainLayout>
