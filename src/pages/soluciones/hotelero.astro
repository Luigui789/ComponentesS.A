---
import MainLayout from "../../layouts/MainLayout.astro";
import Container from "../../components/ui/Container.astro";
import CTA from "../../components/sections/CTA.astro";
---

<MainLayout
    title="Gestión Hotelera OPERA"
    description="Software de PMS para cadenas y hoteles independientes."
>
    <section
        class="pt-32 pb-24 bg-slate-600 border-b border-primary-800 relative overflow-hidden"
    >
        <div class="absolute inset-0 z-0">
            <svg
                class="absolute w-full h-full opacity-10"
                xmlns="http://www.w3.org/2000/svg"
            >
                <defs>
                    <pattern
                        id="grid-pattern-pos"
                        x="0"
                        y="0"
                        width="40"
                        height="40"
                        patternUnits="userSpaceOnUse"
                    >
                        <path
                            d="M 40 0 L 0 0 0 40"
                            fill="none"
                            stroke="white"
                            stroke-width="1"></path>
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#grid-pattern-pos)"
                ></rect>
            </svg>
        </div>
        <div class="absolute inset-0 bg-blue-900/40 mix-blend-multiply"></div>

        <Container className="relative z-10 text-center max-w-4xl">
            <h1
                class="text-5xl md:text-6xl font-heading font-black text-white mb-6"
            >
                Opera PMS
            </h1>
            <h2 class="text-2xl text-secondary-400 font-bold mb-6">
                Gestión hotelera de clase mundial.
            </h2>
            <p
                class="text-xl text-white/90 max-w-3xl mx-auto mb-8 font-medium leading-relaxed"
            >
                Plataforma integral para administrar reservas, habitaciones,
                facturación y experiencia del huésped desde un solo sistema.
            </p>
        </Container>
    </section>

    <section class="py-24 bg-background border-b border-border">
        <Container>
            <div class="grid lg:grid-cols-2 gap-16 items-start">
                <div class="space-y-12">
                    <div>
                        <h2
                            class="text-xs font-bold text-secondary-500 uppercase tracking-widest mb-2 block"
                        >
                            Funcionalidades
                        </h2>
                        <h3
                            class="text-3xl font-heading font-black text-foreground mb-4"
                        >
                            Núcleo de Operación Hotelera
                        </h3>
                        <ul class="space-y-4 text-muted-foreground text-lg">
                            {
                                [
                                    "Gestión de reservas",
                                    "Check-in / Check-out",
                                    "Facturación integrada",
                                    "Control de housekeeping",
                                    "Integración con POS y cerraduras electrónicas",
                                ].map((item) => (
                                    <li class="flex items-center gap-3">
                                        <svg
                                            class="w-5 h-5 text-primary-600 shrink-0"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                            />
                                        </svg>
                                        <span class="font-medium text-foreground">
                                            {item}
                                        </span>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>

                    <div>
                        <h3 class="text-2xl font-bold text-foreground mb-6">
                            Beneficios para tu Hotel
                        </h3>
                        <ul class="space-y-4">
                            {
                                [
                                    "Visión 360° del huésped",
                                    "Optimización de ocupación",
                                    "Automatización operativa",
                                    "Escalabilidad para cadenas hoteleras",
                                ].map((item) => (
                                    <li class="flex items-start gap-3">
                                        <svg
                                            class="w-6 h-6 text-primary-500 shrink-0 mt-0.5"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M5 13l4 4L19 7"
                                            />
                                        </svg>
                                        <span class="text-foreground font-medium">
                                            {item}
                                        </span>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>

                <div class="space-y-12">
                    <img
                        src="https://images.unsplash.com/photo-1562438668-bcf0ca6578f0?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                        alt="Recepción de hotel y experiencia de usuario"
                        class="w-full h-80 object-cover rounded-xl shadow-lg border border-border"
                    />

                    <div
                        class="bg-primary-50 p-8 rounded-xl border border-primary-100"
                    >
                        <h3 class="text-2xl font-bold text-primary-900 mb-6">
                            Ideal para:
                        </h3>
                        <div class="flex flex-wrap gap-3">
                            {
                                [
                                    "Hoteles",
                                    "Resorts",
                                    "Cadenas hoteleras",
                                    "Hostales corporativos",
                                ].map((segment) => (
                                    <span class="px-4 py-2 bg-white text-primary-800 font-semibold rounded-md border border-primary-200 shadow-sm cursor-default hover:bg-primary-100 transition-colors">
                                        {segment}
                                    </span>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>
        </Container>
    </section>

    <CTA />
</MainLayout>
