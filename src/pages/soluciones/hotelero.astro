---
import MainLayout from "../../layouts/MainLayout.astro";
import Container from "../../components/ui/Container.astro";
import CTA from "../../components/sections/CTA.astro";

import { Image } from "astro:assets";

import opera_hotel from "../../assets/industries/Opera/opera_simphony.jpg";

const problems = [
    {
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
        problem: "Ineficiencia operativa",
        solution:
            "Proporciona herramientas de gestión y logística que ayudan a las empresas hoteleras a ser más productivas y eficientes.",
    },
    {
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>`,
        problem: "Falta de soporte local",
        solution:
            "Soporte técnico especializado con más de 27 años de experiencia en Centroamérica, México y el Caribe.",
    },
];

const benefits = [
    {
        title: "Experiencia Comprobada",
        desc: "Instalaciones exitosas en marcas de renombre mundial como Marriott, Hilton, Four Seasons e IHG.",
        icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>`,
    },
    {
        title: "Alcance Internacional",
        desc: "Implementación y soporte en Latinoamérica, Norteamérica y Europa — con equipo especializado en la región.",
        icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    },
];

const features = [
    "Gestión de reservas y disponibilidad",
    "Check-in / Check-out automatizado",
    "Facturación integrada multi-moneda",
    "Control de housekeeping en tiempo real",
    "Integración con POS y cerraduras electrónicas",
    "Reportes de ocupación y revenue",
    "Gestión de tarifas y canales de venta",
];

const clients = ["Marriott", "Hilton", "Four Seasons", "IHG", "Starwood"];
---

<MainLayout
    title="Oracle Hospitality Opera PMS | Componentes S.A."
    description="Soluciones informáticas especializadas para la industria hotelera. PMS de clase mundial con soporte local."
>
    <!-- HERO -->
    <section
        class="pt-32 pb-24 bg-slate-800 border-b border-slate-900 relative overflow-hidden"
    >
        <div class="absolute inset-0 bg-blue-900/30 mix-blend-multiply z-0">
        </div>
        <div class="absolute inset-0 z-0 opacity-10">
            <svg
                class="absolute w-full h-full"
                xmlns="http://www.w3.org/2000/svg"
            >
                <defs
                    ><pattern
                        id="grid-hotel"
                        x="0"
                        y="0"
                        width="40"
                        height="40"
                        patternUnits="userSpaceOnUse"
                        ><path
                            d="M 40 0 L 0 0 0 40"
                            fill="none"
                            stroke="white"
                            stroke-width="1"></path></pattern
                    ></defs
                >
                <rect width="100%" height="100%" fill="url(#grid-hotel)"></rect>
            </svg>
        </div>
        <Container className="relative z-10">
            <div class="grid lg:grid-cols-2 gap-12 items-center">
                <div>
                    <span
                        class="inline-block bg-white/10 text-white text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6 border border-white/20"
                        >Oracle Hospitality — Opera PMS</span
                    >
                    <h1
                        class="text-5xl md:text-6xl font-heading font-black text-white mb-6 leading-tight"
                    >
                        Gestión hotelera de clase mundial.
                    </h1>
                    <p
                        class="text-xl text-white/80 max-w-2xl mb-10 leading-relaxed"
                    >
                        Plataforma integral para administrar reservas,
                        habitaciones, facturación y experiencia del huésped.
                        Respaldada por Componentes S.A. como experto regional
                        con más de 27 años de experiencia.
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <a
                            href="/contacto"
                            class="inline-flex items-center gap-2 px-6 py-3 bg-white text-slate-800 font-bold rounded-lg hover:bg-slate-100 transition-all shadow-lg"
                        >
                            Solicitar demostración
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
                            >
                        </a>
                        <a
                            href="/manuales/opera-pms.pdf"
                            download
                            class="inline-flex items-center gap-2 px-6 py-3 bg-transparent text-white border border-white/40 font-bold rounded-lg hover:bg-white/10 transition-all"
                        >
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path></svg
                            >
                            Descargar Manual
                        </a>
                    </div>
                </div>
                <!-- Imagen representativa a la derecha -->
                <div class="hidden lg:block">
                    <Image
                        src={opera_hotel}
                        alt="Hotel de lujo — Opera PMS"
                        class="w-full h-[420px] object-cover rounded-2xl shadow-2xl border border-white/10 opacity-90"
                    />
                </div>
            </div>
        </Container>
    </section>

    <!-- QUÉ ES -->
    <section class="py-16 bg-card border-b border-border">
        <Container className="max-w-4xl text-center">
            <h2
                class="text-primary-600 font-bold tracking-wide uppercase text-sm mb-3"
            >
                ¿Qué es?
            </h2>
            <h3 class="text-3xl font-heading font-black text-foreground mb-5">
                Soluciones para la Industria Hotelera
            </h3>
            <p class="text-lg text-muted-foreground leading-relaxed">
                Oracle Hospitality Opera son soluciones informáticas
                especializadas para la industria hotelera y de restaurantes,
                respaldadas por la trayectoria de <strong
                    class="text-foreground">Componentes S.A.</strong
                > como experto regional autorizado. Desde una sola plataforma administras
                reservas, habitaciones, tarifas y la experiencia completa del huésped.
            </p>
        </Container>
    </section>

    <!-- PROBLEMAS -->
    <section class="py-20 bg-background border-b border-border">
        <Container>
            <div class="text-center mb-12">
                <h2
                    class="text-primary-600 font-bold tracking-wide uppercase text-sm mb-3"
                >
                    Problemas que resuelve
                </h2>
                <h3 class="text-3xl font-heading font-black text-foreground">
                    Desafíos del sector hotelero, resueltos
                </h3>
            </div>
            <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
                {
                    problems.map((p) => (
                        <div class="bg-card border border-border rounded-2xl p-8 hover:border-primary-300 transition-colors">
                            <div
                                class="w-12 h-12 bg-red-50 text-red-500 rounded-xl flex items-center justify-center mb-5"
                                set:html={p.icon}
                            />
                            <h4 class="font-bold text-foreground text-lg mb-2">
                                {p.problem}
                            </h4>
                            <p class="text-muted-foreground leading-relaxed">
                                {p.solution}
                            </p>
                        </div>
                    ))
                }
            </div>
        </Container>
    </section>

    <!-- BENEFICIOS Y FUNCIONALIDADES -->
    <section class="py-20 bg-muted/30 border-b border-border">
        <Container>
            <div class="grid lg:grid-cols-2 gap-16 items-start">
                <div>
                    <h2
                        class="text-primary-600 font-bold tracking-wide uppercase text-sm mb-3"
                    >
                        Beneficios Clave
                    </h2>
                    <h3
                        class="text-3xl font-heading font-black text-foreground mb-8"
                    >
                        Por qué elegir Opera PMS
                    </h3>
                    <div class="space-y-5 mb-10">
                        {
                            benefits.map((b) => (
                                <div class="flex items-start gap-4 p-5 bg-card border border-border rounded-xl">
                                    <div
                                        class="w-10 h-10 bg-primary-100 text-primary-700 rounded-lg flex items-center justify-center shrink-0 mt-0.5"
                                        set:html={b.icon}
                                    />
                                    <div>
                                        <h4 class="font-bold text-foreground mb-0.5">
                                            {b.title}
                                        </h4>
                                        <p class="text-muted-foreground text-sm">
                                            {b.desc}
                                        </p>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                    <!-- Clientes de referencia -->
                    <div class="bg-card border border-border rounded-xl p-5">
                        <p
                            class="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-3"
                        >
                            Marcas que ya lo usan
                        </p>
                        <div class="flex flex-wrap gap-2">
                            {
                                clients.map((c) => (
                                    <span class="px-3 py-1 bg-muted text-foreground font-semibold rounded-md text-sm border border-border">
                                        {c}
                                    </span>
                                ))
                            }
                        </div>
                    </div>

                    <div class="mt-8 flex gap-3 flex-wrap">
                        <a
                            href="/contacto"
                            class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary-600 text-white font-bold rounded-lg hover:bg-primary-700 transition-all"
                        >
                            Solicitar demo
                        </a>
                        <a
                            href="/manuales/opera-pms.pdf"
                            download
                            class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-primary-700 border border-primary-200 font-bold rounded-lg hover:bg-primary-50 transition-all"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                ></path></svg
                            >
                            Descargar Manual
                        </a>
                    </div>
                </div>

                <div class="flex flex-col items-center">
                    <img
                        src="https://images.unsplash.com/photo-1562438668-bcf0ca6578f0?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                        alt="Recepción de hotel con Opera PMS"
                        class="w-full h-64 object-cover rounded-2xl shadow-lg border border-border mb-6"
                    />

                    <div
                        class="bg-primary-50 border border-primary-100 rounded-2xl p-6 w-full"
                    >
                        <h4 class="font-bold text-primary-900 mb-4">
                            Funcionalidades principales:
                        </h4>
                        <ul class="space-y-2">
                            {
                                features.map((f) => (
                                    <li class="flex items-center gap-2 text-sm text-primary-800 font-medium">
                                        <svg
                                            class="w-4 h-4 text-primary-500 shrink-0"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M5 13l4 4L19 7"
                                            />
                                        </svg>
                                        {f}
                                    </li>
                                ))
                            }
                        </ul>
                        <div class="mt-4 pt-4 border-t border-primary-200">
                            <div class="flex flex-wrap gap-2">
                                {
                                    [
                                        "Hoteles",
                                        "Resorts",
                                        "Cadenas hoteleras",
                                        "Hostales corporativos",
                                    ].map((s) => (
                                        <span class="px-3 py-1.5 bg-white text-primary-800 font-semibold rounded-md border border-primary-200 text-sm">
                                            {s}
                                        </span>
                                    ))
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </Container>
    </section>

    <CTA />
</MainLayout>
