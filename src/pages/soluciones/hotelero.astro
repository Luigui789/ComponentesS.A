---
import MainLayout from "../../layouts/MainLayout.astro";
import Container from "../../components/ui/Container.astro";
import CTA from "../../components/sections/CTA.astro";
---

<MainLayout
    title="Gestión Hotelera OPERA"
    description="Software de PMS para cadenas y hoteles independientes."
>
    <section
        class="pt-32 pb-24 bg-primary-900 text-white relative overflow-hidden"
    >
        <div
            class="absolute inset-0 bg-[url('https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80')] bg-cover bg-center opacity-30 mix-blend-overlay"
        >
        </div>
        <div class="absolute inset-0 bg-blue-900/40 mix-blend-multiply"></div>
        <Container className="relative z-10 text-center max-w-4xl">
            <h1 class="text-5xl md:text-6xl font-black mb-6">
                Soluciones para Hoteles
            </h1>
            <p class="text-xl text-primary-100 max-w-2xl mx-auto mb-8">
                El ecosistema tecnológico hotelero más avanzado. Integra PMS,
                POS, reservas y finanzas en una única plataforma orquestada.
            </p>
        </Container>
    </section>

    <section class="py-24 bg-background">
        <Container>
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="text-3xl font-bold text-foreground mb-4">
                    Integración Completa de Oracle Hospitality
                </h2>
                <p class="text-lg text-muted-foreground">
                    La perfecta armonía entre Oracle Simphony POS y OPERA PMS
                    para ofrecer a los huéspedes una experiencia premium e
                    impecable desde el check-in hasta el restaurante.
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                {
                    [
                        "Posteo a la Habitación",
                        "Perfiles Únicos",
                        "Reportes Consolidados",
                    ].map((feature) => (
                        <div class="p-8 border border-border rounded-2xl bg-card">
                            <h4 class="text-xl font-bold text-foreground mb-3">
                                {feature}
                            </h4>
                            <p class="text-muted-foreground text-sm">
                                La información fluye de manera bidireccional,
                                garantizando que el consumo en F&B se asigne
                                correctamente a la cuenta del huésped en tiempo
                                real.
                            </p>
                        </div>
                    ))
                }
            </div>
        </Container>
    </section>

    <CTA />
</MainLayout>
