---
import MainLayout from "../../layouts/MainLayout.astro";
import Container from "../../components/ui/Container.astro";
import CTA from "../../components/sections/CTA.astro";
---

<MainLayout
    title="Facturación Electrónica Safiro FEL"
    description="Emite facturas electrónicas de forma rápida, segura y cumpliendo la normativa."
>
    <section
        class="pt-32 pb-24 bg-secondary-900 text-white relative overflow-hidden"
    >
        <div
            class="absolute inset-0 bg-gradient-to-br from-secondary-900 via-secondary-800 to-primary-900 -z-10"
        >
        </div>
        <Container className="relative z-10 text-center max-w-4xl">
            <h1 class="text-5xl md:text-6xl font-black mb-6">Sistema Safiro</h1>
            <p class="text-xl text-secondary-100 max-w-2xl mx-auto mb-8">
                Solución tecnológica integral de Inversiones Arguello Tercero,
                S.A., diseñada para automatizar y optimizar la administración de
                empresas y profesionales independientes.
            </p>
        </Container>
    </section>

    <section class="py-24 bg-background">
        <Container>
            <div class="grid md:grid-cols-2 gap-16 items-center">
                <div class="order-2 md:order-1">
                    <h2 class="text-3xl font-bold text-foreground mb-6">
                        Módulos del Sistema Safiro
                    </h2>
                    <ul class="space-y-4">
                        <li class="flex gap-4">
                            <div
                                class="w-8 h-8 rounded-full bg-secondary-100 flex items-center justify-center flex-shrink-0 mt-1"
                            >
                                <svg
                                    class="w-4 h-4 text-secondary-600"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                    ></path></svg
                                >
                            </div>
                            <div>
                                <h4 class="font-bold text-foreground">
                                    Contabilidad General y Presupuesto
                                </h4>
                                <p class="text-muted-foreground text-sm">
                                    Control absoluto de los estados financieros
                                    e impecable planificación de recursos.
                                </p>
                            </div>
                        </li>
                        <li class="flex gap-4">
                            <div
                                class="w-8 h-8 rounded-full bg-secondary-100 flex items-center justify-center flex-shrink-0 mt-1"
                            >
                                <svg
                                    class="w-4 h-4 text-secondary-600"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"
                                    ></path></svg
                                >
                            </div>
                            <div>
                                <h4 class="font-bold text-foreground">
                                    Cuentas por Cobrar y Pagar
                                </h4>
                                <p class="text-muted-foreground text-sm">
                                    Gestión eficiente de obligaciones con
                                    proveedores y administración proactiva de la
                                    cartera de clientes.
                                </p>
                            </div>
                        </li>
                        <li class="flex gap-4">
                            <div
                                class="w-8 h-8 rounded-full bg-secondary-100 flex items-center justify-center flex-shrink-0 mt-1"
                            >
                                <svg
                                    class="w-4 h-4 text-secondary-600"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"
                                    ></path></svg
                                >
                            </div>
                            <div>
                                <h4 class="font-bold text-foreground">
                                    Control de Inventarios
                                </h4>
                                <p class="text-muted-foreground text-sm">
                                    Control preciso de existencias y movimientos
                                    de mercadería multicentro en tiempo real.
                                </p>
                            </div>
                        </li>
                    </ul>
                </div>
                <div class="order-1 md:order-2">
                    <img
                        src="https://images.unsplash.com/photo-1554224155-8d04cb21cd6c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                        alt="Facturación electrónica y finanzas"
                        class="rounded-2xl shadow-xl w-full"
                    />
                </div>
            </div>
        </Container>
    </section>

    <CTA />
</MainLayout>
