---
import MainLayout from "../../layouts/MainLayout.astro";
import Container from "../../components/ui/Container.astro";
import CTA from "../../components/sections/CTA.astro";
---

<MainLayout
    title="Facturación Electrónica Safiro ERP"
    description="Emite facturas electrónicas de forma rápida, segura y cumpliendo la normativa."
>
    <section
        class="pt-32 pb-24 bg-primary-800 border-b border-primary-800 relative overflow-hidden"
    >
        <div class="absolute inset-0 z-0">
            <svg
                class="absolute w-full h-full opacity-10"
                xmlns="http://www.w3.org/2000/svg"
            >
                <defs>
                    <pattern
                        id="grid-pattern-pos"
                        x="0"
                        y="0"
                        width="40"
                        height="40"
                        patternUnits="userSpaceOnUse"
                    >
                        <path
                            d="M 40 0 L 0 0 0 40"
                            fill="none"
                            stroke="white"
                            stroke-width="1"></path>
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#grid-pattern-pos)"
                ></rect>
            </svg>
        </div>
        <Container className="relative z-10 text-center max-w-4xl">
            <h1
                class="text-5xl md:text-6xl font-heading font-black text-white mb-6"
            >
                Safiro ERP
            </h1>
            <h2 class="text-2xl text-secondary-400 font-bold mb-6">
                Sistema contable nacional diseñado para control financiero
                total.
            </h2>
            <p
                class="text-xl text-white/90 max-w-3xl mx-auto mb-8 font-medium leading-relaxed"
            >
                Plataforma integral que centraliza contabilidad, inventarios y
                facturación electrónica bajo estricta normativa nacional.
            </p>
        </Container>
    </section>

    <section class="py-24 bg-background border-b border-border">
        <Container>
            <div class="grid lg:grid-cols-2 gap-16 items-start">
                <div class="space-y-12">
                    <div>
                        <h2
                            class="text-xs font-bold text-secondary-500 uppercase tracking-widest mb-2 block"
                        >
                            Módulos Principales
                        </h2>
                        <h3
                            class="text-3xl font-heading font-black text-foreground mb-4"
                        >
                            Arquitectura Modular
                        </h3>
                        <ul class="space-y-4 text-muted-foreground text-lg">
                            {
                                [
                                    "Contabilidad general",
                                    "Presupuesto",
                                    "Cuentas por cobrar y pagar",
                                    "Inventarios",
                                    "Facturación electrónica",
                                ].map((item) => (
                                    <li class="flex items-center gap-3">
                                        <svg
                                            class="w-5 h-5 text-primary-600 shrink-0"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                                            />
                                        </svg>
                                        <span class="font-medium text-foreground">
                                            {item}
                                        </span>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>

                    <div>
                        <h3 class="text-2xl font-bold text-foreground mb-6">
                            Beneficios Operativos
                        </h3>
                        <ul class="space-y-4">
                            {
                                [
                                    "Cumplimiento fiscal nacional garantizado",
                                    "Control financiero en tiempo real",
                                    "Información corporativa centralizada",
                                    "Reportes estratégicos para toma de decisiones",
                                ].map((item) => (
                                    <li class="flex items-start gap-3">
                                        <svg
                                            class="w-6 h-6 text-primary-500 shrink-0 mt-0.5"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M5 13l4 4L19 7"
                                            />
                                        </svg>
                                        <span class="text-foreground font-medium">
                                            {item}
                                        </span>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>

                <div class="space-y-12">
                    <img
                        src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                        alt="Dashboard y gráficos de Safiro ERP"
                        class="w-full h-80 object-cover rounded-xl shadow-lg border border-border"
                    />

                    <div
                        class="bg-primary-50 p-8 rounded-xl border border-primary-100"
                    >
                        <h3 class="text-2xl font-bold text-primary-900 mb-6">
                            Ideal para:
                        </h3>
                        <div class="flex flex-wrap gap-3">
                            {
                                [
                                    "Empresas medianas y grandes",
                                    "Negocios con múltiples sucursales",
                                    "Organizaciones con cumplimiento fiscal estricto",
                                ].map((segment) => (
                                    <span class="px-4 py-2 bg-white text-primary-800 font-semibold rounded-md border border-primary-200 shadow-sm cursor-default hover:bg-primary-100 transition-colors">
                                        {segment}
                                    </span>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>
        </Container>
    </section>

    <CTA />
</MainLayout>
