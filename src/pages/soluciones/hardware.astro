---
import MainLayout from "../../layouts/MainLayout.astro";
import Container from "../../components/ui/Container.astro";
import CTA from "../../components/sections/CTA.astro";
import { Image } from "astro:assets";

import termImg from "../../assets/hardware/ws655.png";
import kdsImg from "../../assets/hardware/tablet micros 700.png";
import printerImg from "../../assets/hardware/epson-tmu-220.png";
import oracleImg from "../../assets/hardware/oracle-post-integrations.png";
---

<MainLayout
    title="Hardware y Equipamiento POS"
    description="Terminales, impresoras, y periféricos certificados de alta durabilidad."
>
    <section
        class="pt-32 pb-24 bg-slate-900 border-b border-primary-800 relative overflow-hidden"
    >
        <div class="absolute inset-0 z-0">
            <svg
                class="absolute w-full h-full opacity-10"
                xmlns="http://www.w3.org/2000/svg"
            >
                <defs>
                    <pattern
                        id="grid-pattern-pos"
                        x="0"
                        y="0"
                        width="40"
                        height="40"
                        patternUnits="userSpaceOnUse"
                    >
                        <path
                            d="M 40 0 L 0 0 0 40"
                            fill="none"
                            stroke="white"
                            stroke-width="1"></path>
                    </pattern>
                </defs>
                <rect width="100%" height="100%" fill="url(#grid-pattern-pos)"
                ></rect>
            </svg>
        </div>
        <Container className="relative z-10">
            <div class="max-w-3xl">
                <span
                    class="inline-block bg-white/10 text-white text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6 border border-white/20"
                    >Hardware Industrial & Periféricos</span
                >
                <h1
                    class="text-5xl md:text-6xl font-black mb-6 text-white leading-tight"
                >
                    Equipamiento certificado para el ritmo de tu operación.
                </h1>
                <p
                    class="text-xl text-slate-300 max-w-2xl mb-10 font-medium leading-relaxed"
                >
                    Tecnología de alto rendimiento diseñada para trabajar en
                    armonía con el software de gestión, bajo una API abierta y
                    segura sobre Microsoft Windows u Oracle Linux.
                </p>
                <div class="flex flex-wrap gap-4">
                    <a
                        href="/contacto"
                        class="inline-flex items-center gap-2 px-6 py-3 bg-white text-slate-800 font-bold rounded-lg hover:bg-slate-100 transition-all shadow-lg"
                    >
                        Cotizar equipos
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
                        >
                    </a>
                    <a
                        href="/manuales/hardware-micros.pdf"
                        download
                        class="inline-flex items-center gap-2 px-6 py-3 bg-transparent text-white border border-white/40 font-bold rounded-lg hover:bg-white/10 transition-all"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                            ></path></svg
                        >
                        Descargar Catálogo
                    </a>
                </div>
            </div>
        </Container>
    </section>

    <!-- QUE ES -->
    <section class="py-16 bg-card border-b border-border">
        <Container className="max-w-4xl text-center">
            <h2
                class="text-primary-600 font-bold tracking-wide uppercase text-sm mb-3"
            >
                ¿Qué es?
            </h2>
            <h3 class="text-3xl font-heading font-black text-foreground mb-5">
                Hardware de Grado Industrial
            </h3>
            <p class="text-lg text-muted-foreground leading-relaxed">
                Equipamiento tecnológico de <strong class="text-foreground"
                    >alto rendimiento</strong
                > diseñado para entornos de alta demanda en el sector hospitalidad
                y retail. Todos los periféricos operan bajo una API abierta y segura,
                compatible con Microsoft Windows u Oracle Linux, garantizando compatibilidad
                total con el software de gestión.
            </p>
        </Container>
    </section>

    <!-- PROBLEMAS Y BENEFICIOS -->
    <section class="py-20 bg-background border-b border-border">
        <Container>
            <div class="grid lg:grid-cols-2 gap-16 items-start">
                <div class="space-y-10">
                    <div>
                        <h2
                            class="text-primary-600 font-bold tracking-wide uppercase text-sm mb-3"
                        >
                            Problemas que resuelve
                        </h2>
                        <h3
                            class="text-3xl font-heading font-black text-foreground mb-6"
                        >
                            Equipos que aguantan el ritmo
                        </h3>
                        <div class="space-y-5">
                            <div
                                class="flex items-start gap-4 p-5 bg-card border border-border rounded-xl"
                            >
                                <div
                                    class="w-10 h-10 bg-red-50 text-red-500 rounded-lg flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-5 h-5"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                                        ></path></svg
                                    >
                                </div>
                                <div>
                                    <h4 class="font-bold text-foreground mb-1">
                                        Equipos domésticos poco resistentes
                                    </h4>
                                    <p class="text-muted-foreground text-sm">
                                        Hardware diseñado para el ritmo del
                                        sector hospitalidad: pantallas táctiles
                                        de cocina, terminales POS y displays
                                        sellados contra derrames.
                                    </p>
                                </div>
                            </div>
                            <div
                                class="flex items-start gap-4 p-5 bg-card border border-border rounded-xl"
                            >
                                <div
                                    class="w-10 h-10 bg-red-50 text-red-500 rounded-lg flex items-center justify-center shrink-0"
                                >
                                    <svg
                                        class="w-5 h-5"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                        ><path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                                        ></path></svg
                                    >
                                </div>
                                <div>
                                    <h4 class="font-bold text-foreground mb-1">
                                        Incompatibilidad técnica
                                    </h4>
                                    <p class="text-muted-foreground text-sm">
                                        Todos los periféricos funcionan bajo una
                                        API abierta y segura sobre Microsoft
                                        Windows u Oracle Linux, listos para
                                        integrar con Oracle Simphony.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div>
                        <h3 class="text-xl font-bold text-foreground mb-4">
                            Beneficios Clave
                        </h3>
                        <div class="space-y-3">
                            <div class="flex items-start gap-3">
                                <svg
                                    class="w-5 h-5 text-primary-500 shrink-0 mt-0.5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                >
                                <div>
                                    <span class="font-bold text-foreground"
                                        >Ecosistema Completo:
                                    </span><span
                                        class="text-muted-foreground text-sm"
                                        >Estaciones táctiles, lectores EMV,
                                        impresoras de recibos, básculas y
                                        lectores de códigos de barras.</span>
                                </div>
                            </div>
                            <div class="flex items-start gap-3">
                                <svg
                                    class="w-5 h-5 text-primary-500 shrink-0 mt-0.5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                >
                                <div>
                                    <span class="font-bold text-foreground"
                                        >Seguridad y Control:
                                    </span><span
                                        class="text-muted-foreground text-sm"
                                        >Lectores de huellas dactilares para un
                                        manejo riguroso de seguridad y auditoría
                                        del personal.</span>
                                </div>
                            </div>
                            <div class="flex items-start gap-3">
                                <svg
                                    class="w-5 h-5 text-primary-500 shrink-0 mt-0.5"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                >
                                <div>
                                    <span class="font-bold text-foreground"
                                        >Soporte Local:
                                    </span><span
                                        class="text-muted-foreground text-sm"
                                        >Técnicos certificados en Nicaragua.
                                        Garantía oficial y equipos de respaldo
                                        para cero tiempo muerto.</span>
                                </div>
                            </div>
                        </div>
                        <div class="mt-8 flex gap-3 flex-wrap">
                            <a
                                href="/contacto"
                                class="inline-flex items-center gap-2 px-5 py-2.5 bg-primary-600 text-white font-bold rounded-lg hover:bg-primary-700 transition-all"
                                >Cotizar equipos</a
                            >
                            <a
                                href="/manuales/hardware-micros.pdf"
                                download
                                class="inline-flex items-center gap-2 px-5 py-2.5 bg-white text-primary-700 border border-primary-200 font-bold rounded-lg hover:bg-primary-50 transition-all"
                            >
                                <svg
                                    class="w-4 h-4"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
                                    ></path></svg
                                >
                                Descargar Catálogo
                            </a>
                        </div>
                    </div>
                </div>

                <div class="space-y-12">
                    <div>
                        <h2
                            class="text-xs font-bold text-secondary-500 uppercase tracking-widest mb-2 block"
                        >
                            Ventajas Competitivas
                        </h2>
                        <h3
                            class="text-3xl font-heading font-black text-foreground mb-4"
                        >
                            Hardware y Gestión Integrada
                        </h3>
                        <ul class="space-y-4 text-muted-foreground text-lg">
                            {
                                [
                                    "Terminales certificadas",
                                    "Impresoras fiscales integradas",
                                    "Control de inventario",
                                    "Gestión de caja",
                                    "Reportes operativos",
                                ].map((item) => (
                                    <li class="flex items-center gap-3">
                                        <svg
                                            class="w-5 h-5 text-primary-600 shrink-0"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                            />
                                        </svg>
                                        <span class="font-medium text-foreground">
                                            {item}
                                        </span>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>

                    <div>
                        <h3 class="text-2xl font-bold text-foreground mb-6">
                            Ventajas Competitivas
                        </h3>
                        <ul class="space-y-4">
                            {
                                [
                                    "Estabilidad comprobada en producción",
                                    "Integración nativa hardware/software",
                                    "Soporte técnico y reparación especializada local",
                                    "Clasificación Enterprise para entornos exigentes",
                                ].map((item) => (
                                    <li class="flex items-start gap-3">
                                        <svg
                                            class="w-6 h-6 text-primary-500 shrink-0 mt-0.5"
                                            fill="none"
                                            viewBox="0 0 24 24"
                                            stroke="currentColor"
                                        >
                                            <path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M5 13l4 4L19 7"
                                            />
                                        </svg>
                                        <span class="text-foreground font-medium">
                                            {item}
                                        </span>
                                    </li>
                                ))
                            }
                        </ul>
                    </div>
                </div>

                <div class="space-y-12">
                    <Image
                        src={oracleImg}
                        alt="Terminales de punto de venta Micros en restaurante"
                        class="w-full h-110 object-cover rounded-xl shadow-lg border border-border"
                    />

                    <div
                        class="bg-primary-50 p-8 rounded-xl border border-primary-100"
                    >
                        <h3 class="text-2xl font-bold text-primary-900 mb-6">
                            Ideal para:
                        </h3>
                        <div class="flex flex-wrap gap-3">
                            {
                                [
                                    "Restaurantes de alto tráfico",
                                    "Hoteles",
                                    "Operaciones con múltiples puntos de venta",
                                ].map((segment) => (
                                    <span class="px-4 py-2 bg-white text-primary-800 font-semibold rounded-md border border-primary-200 shadow-sm cursor-default hover:bg-primary-100 transition-colors">
                                        {segment}
                                    </span>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>
        </Container>
    </section>

    <!-- Hardward Catalog Section -->
    <section class="py-24 bg-muted/30">
        <Container>
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2
                    class="text-primary-600 font-bold tracking-wide uppercase text-sm mb-3"
                >
                    Catálogo Especializado
                </h2>
                <h3
                    class="text-4xl font-heading font-black text-foreground mb-6"
                >
                    Equipamiento Certificado Micros
                </h3>
                <p class="text-lg text-muted-foreground">
                    Encuentra el hardware exacto que tu operación necesita.
                    Diseñado para resistir derrames, calor extremo y uso
                    continuo.
                </p>
            </div>

            <div class="space-y-24">
                <!-- Producto 1: Terminales -->
                <div class="grid md:grid-cols-2 gap-12 items-center">
                    <div class="order-2 md:order-1 space-y-6">
                        <div
                            class="inline-flex items-center justify-center p-3 bg-primary-100 text-primary-700 rounded-xl mb-2"
                        >
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                                ></path></svg
                            >
                        </div>
                        <h4 class="text-3xl font-bold text-foreground">
                            Terminales POS / Workstation
                        </h4>
                        <p
                            class="text-muted-foreground text-lg leading-relaxed"
                        >
                            Hardware de grado comercial con pantallas táctiles
                            selladas anti-derrames y amplio poder de
                            procesamiento para despachar comandas a máxima
                            velocidad.
                        </p>
                        <ul class="space-y-3 mb-8">
                            <li
                                class="flex items-center gap-2 text-foreground font-medium"
                            >
                                <svg
                                    class="w-5 h-5 text-secondary-500"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                > Pantalla anti-reflejante Full HD
                            </li>
                            <li
                                class="flex items-center gap-2 text-foreground font-medium"
                            >
                                <svg
                                    class="w-5 h-5 text-secondary-500"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                > Chasis metálico para disipación de calor
                            </li>
                            <li
                                class="flex items-center gap-2 text-foreground font-medium"
                            >
                                <svg
                                    class="w-5 h-5 text-secondary-500"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                > Múltiples puertos COM / USB industriales
                            </li>
                        </ul>
                        <a
                            href="/contacto?producto=Terminales%20POS"
                            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-primary-700 border-2 border-primary-200 hover:border-primary-600 hover:bg-primary-50 rounded-lg font-bold transition-all w-full sm:w-auto"
                        >
                            <span>Cotizar Terminales</span>
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
                            >
                        </a>
                    </div>
                    <div class="order-1 md:order-2">
                        <Image
                            src={termImg}
                            alt="Terminales POS"
                            class="w-full h-[400px] object-contain bg-white p-8 rounded-2xl shadow-xl border border-border"
                        />
                    </div>
                </div>

                <!-- Producto 2: Kitchen Display -->
                <div class="grid md:grid-cols-2 gap-12 items-center">
                    <div class="order-1 md:order-1">
                        <Image
                            src={kdsImg}
                            alt="Kitchen Display System"
                            class="w-full h-[400px] object-contain bg-white p-8 rounded-2xl shadow-xl border border-border"
                        />
                    </div>
                    <div class="order-2 md:order-2 space-y-6">
                        <div
                            class="inline-flex items-center justify-center p-3 bg-primary-100 text-primary-700 rounded-xl mb-2"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="1.5"
                                stroke="currentColor"
                                class="size-6"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"
                                ></path>
                            </svg>
                        </div>
                        <h4 class="text-3xl font-bold text-foreground">
                            Kitchen Display Systems (KDS)
                        </h4>
                        <p
                            class="text-muted-foreground text-lg leading-relaxed"
                        >
                            Monitores de despacho directo para cocinas y áreas
                            de preparación. Elimina el papel, controla tiempos
                            de cocción y prioriza órdenes automáticamente.
                        </p>
                        <ul class="space-y-3 mb-8">
                            <li
                                class="flex items-center gap-2 text-foreground font-medium"
                            >
                                <svg
                                    class="w-5 h-5 text-secondary-500"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                > Resistente a vapores y grasas de cocina
                            </li>
                            <li
                                class="flex items-center gap-2 text-foreground font-medium"
                            >
                                <svg
                                    class="w-5 h-5 text-secondary-500"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                > Alertas visuales de retraso de órdenes
                            </li>
                            <li
                                class="flex items-center gap-2 text-foreground font-medium"
                            >
                                <svg
                                    class="w-5 h-5 text-secondary-500"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke="currentColor"
                                    ><path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M5 13l4 4L19 7"></path></svg
                                > Panel de mandos y botoneras de acero templado
                            </li>
                        </ul>
                        <a
                            href="/contacto?producto=Monitores%20KDS"
                            class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-white text-primary-700 border-2 border-primary-200 hover:border-primary-600 hover:bg-primary-50 rounded-lg font-bold transition-all w-full sm:w-auto"
                        >
                            <span>Cotizar KDS</span>
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
                            >
                        </a>
                    </div>
                </div>

                <!-- Producto 3: Impresoras -->
                <div class="grid md:grid-cols-2 gap-12 items-center">
                    <div class="order-2 md:order-1 space-y-6">
                        <div
                            class="inline-flex items-center justify-center p-3 bg-primary-100 text-primary-700 rounded-xl mb-2"
                        >
                            <svg
                                class="w-6 h-6"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"
                                ></path></svg
                            >
                        </div>
                        <h4 class="text-3xl font-bold text-foreground">
                            Impresoras Térmicas y de Impacto
                        </h4>
                        <p
                            class="text-muted-foreground text-lg leading-relaxed"
                        >
                            Impresión ininterrumpida de tickets para clientes e
