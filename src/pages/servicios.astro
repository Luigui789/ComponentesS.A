---
import MainLayout from "../layouts/MainLayout.astro";
import Container from "../components/ui/Container.astro";
import CTA from "../components/sections/CTA.astro";
---

<MainLayout
    title="Nuestros Servicios"
    description="Explora los servicios de consultoría e implementación."
>
    <section class="pt-32 pb-24 bg-card border-b border-border">
        <Container className="text-center max-w-4xl">
            <h1 class="text-5xl md:text-6xl font-black mb-6 text-foreground">
                Servicios y Asesoría
            </h1>
            <p class="text-xl text-muted-foreground mx-auto">
                La implementación de nuestras soluciones se complementa con la
                experiencia comprobada de Componentes S.A.
            </p>
        </Container>
    </section>

    <section class="py-24 bg-background">
        <Container>
            <div class="grid md:grid-cols-2 gap-8">
                <!-- Asesoría -->
                <div class="bg-card p-8 rounded-2xl border border-border">
                    <div
                        class="w-14 h-14 bg-primary-100 text-primary-600 rounded-xl flex items-center justify-center mb-6"
                    >
                        <svg
                            class="w-7 h-7"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                            ></path></svg
                        >
                    </div>
                    <h3 class="text-2xl font-bold mb-3 text-foreground">
                        Asesoría en Sistemas
                    </h3>
                    <p class="text-muted-foreground">
                        Evaluación técnica integral previa para garantizar que
                        Safiro o Simphony se adapten al 100% de los flujos de tu
                        negocio.
                    </p>
                </div>
                <!-- Venta y soporte -->
                <div
                    class="bg-card p-8 rounded-2xl border border-border border-primary-500 shadow-md"
                >
                    <div
                        class="w-14 h-14 bg-primary-600 text-white rounded-xl flex items-center justify-center mb-6"
                    >
                        <svg
                            class="w-7 h-7"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"
                            ></path></svg
                        >
                    </div>
                    <h3 class="text-2xl font-bold mb-3 text-foreground">
                        Venta y Soporte
                    </h3>
                    <p class="text-muted-foreground">
                        Implementación, configuración y capacitación total de tu
                        personal. El costo del software se adapta siempre según
                        la escala y personalización de tu operación.
                    </p>
                </div>
            </div>
        </Container>
    </section>
    <CTA />
</MainLayout>
