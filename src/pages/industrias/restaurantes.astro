---
import MainLayout from "../../layouts/MainLayout.astro";
import Container from "../../components/ui/Container.astro";
import CTA from "../../components/sections/CTA.astro";
---

<MainLayout
    title="Soluciones para Restaurantes"
    description="Agiliza la toma de pedidos y controla el inventario en tiempo real."
>
    <section class="pt-32 pb-24 bg-card border-b border-border">
        <Container className="text-center max-w-4xl">
            <h1 class="text-5xl md:text-6xl font-black mb-6 text-foreground">
                Restaurantes y Bares
            </h1>
            <p class="text-xl text-muted-foreground mx-auto">
                Desde cafeterías boutique hasta restaurantes de alta cocina,
                proveemos la plataforma Oracle Simphony para que ofrezcas
                experiencias memorables a tus comensales.
            </p>
        </Container>
    </section>
    <CTA />
</MainLayout>
