---
import MainLayout from "../../layouts/MainLayout.astro";
import Container from "../../components/ui/Container.astro";
import CTA from "../../components/sections/CTA.astro";

const problems = [
    {
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
        problem: "Operaciones desconectadas",
        solution:
            "POS y PMS integrados: lo que se consume en el restaurante del hotel se factura automáticamente a la habitación.",
    },
    {
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2z"/></svg>`,
        problem: "Facturación manual lenta",
        solution:
            "Cierre de cuenta rápido: cargos a habitación, pago en mostrador o app en segundos.",
    },
    {
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>`,
        problem: "Sin visibilidad del negocio",
        solution:
            "Reportes unificados de bar, restaurante, spa y habitaciones desde un solo panel corporativo.",
    },
    {
        icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>`,
        problem: "Pagos fragmentados",
        solution:
            "Acepta tarjetas, pagos móviles y divisas extranjeras en todos los puntos de venta del hotel.",
    },
];

const benefits = [
    {
        title: "POS + PMS integrados",
        desc: "Oracle Simphony + Opera PMS funcionan como un solo sistema: cargos automáticos a la habitación, sin fricciones.",
    },
    {
        title: "Puntos de venta distribuidos",
        desc: "Bar, restaurante, piscina, spa — todos conectados y reportando en tiempo real al mismo sistema.",
    },
    {
        title: "Control de inventario unificado",
        desc: "Recetas, stock y compras centralizadas para toda la operación de alimentos y bebidas del hotel.",
    },
    {
        title: "Experiencia premium del huésped",
        desc: "Check-in rápido, ordenes desde la habitación y factura express para aumentar la satisfacción.",
    },
];

const useCases = [
    "Hoteles boutique",
    "Grandes cadenas hoteleras",
    "Resorts all-inclusive",
    "Apart-hoteles",
    "Hoteles de aeropuerto",
    "Spas y centros de bienestar",
];

const clients = [
    "Marriott",
    "Hilton",
    "Four Seasons",
    "Hyatt Place",
    "InterContinental",
    "Guacalito Nicaragua",
    "Rancho Santana",
];
---

<MainLayout
    title="Soluciones para Hoteles y Resorts | Componentes S.A."
    description="Oracle Simphony POS + Opera PMS para hoteles y resorts: integración total de restaurante, bar, spa y habitaciones."
>
    <!-- HERO -->
    <section
        class="pt-32 pb-24 bg-primary-900 border-b border-primary-950 relative overflow-hidden"
    >
        <div class="absolute inset-0 z-0 opacity-10">
            <svg
                class="absolute w-full h-full"
                xmlns="http://www.w3.org/2000/svg"
            >
                <defs
                    ><pattern
                        id="grid-hotel"
                        x="0"
                        y="0"
                        width="40"
                        height="40"
                        patternUnits="userSpaceOnUse"
                        ><path
                            d="M 40 0 L 0 0 0 40"
                            fill="none"
                            stroke="white"
                            stroke-width="1"></path></pattern
                    ></defs
                >
                <rect width="100%" height="100%" fill="url(#grid-hotel)"></rect>
            </svg>
        </div>
        <Container className="relative z-10">
            <div class="grid lg:grid-cols-2 gap-12 items-center">
                <div>
                    <span
                        class="inline-block bg-white/10 text-white text-xs font-bold uppercase tracking-widest px-4 py-1.5 rounded-full mb-6 border border-white/20"
                        >Industria — Hoteles & Resorts</span
                    >
                    <h1
                        class="text-5xl md:text-6xl font-heading font-black text-white mb-6 leading-tight"
                    >
                        El estándar dorado en hospitalidad hotelera.
                    </h1>
                    <p
                        class="text-xl text-white/80 max-w-2xl mb-10 leading-relaxed"
                    >
                        Conecta POS, PMS y facturación en una sola plataforma.
                        La dupla Oracle Simphony + Opera es el estándar de
                        hoteles de clase mundial. Con soporte local de
                        Componentes S.A.
                    </p>
                    <div class="flex flex-wrap gap-4">
                        <a
                            href="/contacto"
                            class="inline-flex items-center gap-2 px-6 py-3 bg-white text-primary-900 font-bold rounded-lg hover:bg-primary-50 transition-all shadow-lg"
                        >
                            Solicitar demostración
                            <svg
                                class="w-5 h-5"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke="currentColor"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
                            >
                        </a>
                        <a
                            href="/soluciones/hotelero"
                            class="inline-flex items-center gap-2 px-6 py-3 bg-transparent text-white border border-white/40 font-bold rounded-lg hover:bg-white/10 transition-all"
                        >
                            Ver Opera PMS
                        </a>
                    </div>
                </div>
                <div class="hidden lg:block">
                    <img
                        src="https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&auto=format&fit=crop&w=900&q=80"
                        alt="Hotel de lujo con tecnología de gestión"
                        class="w-full h-[420px] object-cover rounded-2xl shadow-2xl border border-white/10 opacity-90"
                        loading="lazy"
                    />
                </div>
            </div>
        </Container>
    </section>

    <!-- PROBLEMAS -->
    <section class="py-20 bg-background border-b border-border">
        <Container>
            <div class="text-center mb-12">
                <h2
                    class="text-primary-600 font-bold tracking-wide uppercase text-sm mb-3"
                >
                    Problemas que resolvemos
                </h2>
                <h3 class="text-3xl font-heading font-black text-foreground">
                    Los retos operativos de un hotel, resueltos
                </h3>
            </div>
            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
                {
                    problems.map((p) => (
                        <div class="bg-card border border-border rounded-2xl p-6 hover:border-primary-300 transition-colors">
                            <div
                                class="w-11 h-11 bg-red-50 text-red-500 rounded-xl flex items-center justify-center mb-4"
                                set:html={p.icon}
                            />
                            <h4 class="font-bold text-foreground mb-2">
                                {p.problem}
                            </h4>
                            <p class="text-muted-foreground text-sm leading-relaxed">
                                {p.solution}
                            </p>
                        </div>
                    ))
                }
            </div>
        </Container>
    </section>

    <!-- BENEFICIOS -->
    <section class="py-20 bg-muted/30 border-b border-border">
        <Container>
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div>
                    <h2
                        class="text-primary-600 font-bold tracking-wide uppercase text-sm mb-3"
                    >
                        Beneficios Clave
                    </h2>
                    <h3
                        class="text-3xl font-heading font-black text-foreground mb-8"
                    >
                        Una sola plataforma para toda tu propiedad
                    </h3>
                    <div class="space-y-5">
                        {
                            benefits.map((b) => (
                                <div class="flex items-start gap-4 p-5 bg-card border border-border rounded-xl">
                                    <svg
                                        class="w-5 h-5 text-primary-500 shrink-0 mt-0.5"
                                        fill="none"
                                        viewBox="0 0 24 24"
                                        stroke="currentColor"
                                    >
                                        <path
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                            stroke-width="2"
                                            d="M5 13l4 4L19 7"
                                        />
                                    </svg>
                                    <div>
                                        <h4 class="font-bold text-foreground mb-0.5">
                                            {b.title}
                                        </h4>
                                        <p class="text-muted-foreground text-sm">
                                            {b.desc}
                                        </p>
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>
                <div class="space-y-6">
                    <img
                        src="https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                        alt="Recepción de hotel con sistema PMS"
                        class="w-full h-64 object-cover rounded-2xl shadow-lg border border-border"
                        loading="lazy"
                    />
                    <div
                        class="bg-primary-50 border border-primary-100 rounded-2xl p-6"
                    >
                        <h4 class="font-bold text-primary-900 mb-3">
                            Ideal para:
                        </h4>
                        <div class="flex flex-wrap gap-2">
                            {
                                useCases.map((u) => (
                                    <span class="px-3 py-1.5 bg-white text-primary-800 font-semibold rounded-md border border-primary-200 text-sm hover:bg-primary-100 transition-colors cursor-default">
                                        {u}
                                    </span>
                                ))
                            }
                        </div>
                    </div>
                    <!-- Clientes de referencia -->
                    <div class="bg-card border border-border rounded-2xl p-5">
                        <p
                            class="text-xs font-bold uppercase tracking-widest text-muted-foreground mb-3"
                        >
                            Marcas que confían en nosotros
                        </p>
                        <div class="flex flex-wrap gap-2">
                            {
                                clients.map((c) => (
                                    <span class="px-3 py-1 bg-muted text-foreground font-semibold rounded-md text-sm border border-border">
                                        {c}
                                    </span>
                                ))
                            }
                        </div>
                    </div>
                </div>
            </div>
        </Container>
    </section>

    <!-- SOLUCIONES RELACIONADAS -->
    <section class="py-16 bg-card border-b border-border">
        <Container>
            <div class="text-center mb-10">
                <h2 class="text-2xl font-heading font-black text-foreground">
                    Soluciones recomendadas para tu hotel
                </h2>
            </div>
            <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
                <a
                    href="/soluciones/hotelero"
                    aria-label="Opera PMS"
                    class="flex items-start gap-4 p-6 bg-background border border-border rounded-2xl hover:border-primary-400 hover:shadow-md transition-all group"
                >
                    <div
                        class="w-12 h-12 bg-primary-100 text-primary-600 rounded-xl flex items-center justify-center shrink-0"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                            ></path></svg
                        >
                    </div>
                    <div>
                        <h4
                            class="font-bold text-foreground mb-1 group-hover:text-primary-600 transition-colors"
                        >
                            Oracle Hospitality Opera PMS
                        </h4>
                        <p class="text-muted-foreground text-sm">
                            Gestión integral de la propiedad: reservas,
                            habitaciones y huéspedes.
                        </p>
                    </div>
                </a>
                <a
                    href="/soluciones/pos"
                    aria-label="Oracle Simphony POS"
                    class="flex items-start gap-4 p-6 bg-background border border-border rounded-2xl hover:border-primary-400 hover:shadow-md transition-all group"
                >
                    <div
                        class="w-12 h-12 bg-secondary-100 text-secondary-600 rounded-xl flex items-center justify-center shrink-0"
                    >
                        <svg
                            class="w-6 h-6"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
                            ></path></svg
                        >
                    </div>
                    <div>
                        <h4
                            class="font-bold text-foreground mb-1 group-hover:text-primary-600 transition-colors"
                        >
                            Oracle Simphony POS
                        </h4>
                        <p class="text-muted-foreground text-sm">
                            POS para restaurantes y bares del hotel integrado
                            con Opera.
                        </p>
                    </div>
                </a>
            </div>
        </Container>
    </section>

    <CTA />
</MainLayout>
