---
import MainLayout from "../../layouts/MainLayout.astro";
import Container from "../../components/ui/Container.astro";
import CTA from "../../components/sections/CTA.astro";
---

<MainLayout
    title="Soluciones para Retail"
    description="Punto de venta robusto y rápido para cualquier entorno de compras."
>
    <section class="pt-32 pb-24 bg-card border-b border-border">
        <Container className="text-center max-w-4xl">
            <h1 class="text-5xl md:text-6xl font-black mb-6 text-foreground">
                Retail y Tiendas
            </h1>
            <p class="text-xl text-muted-foreground mx-auto">
                Sistemas rápidos, eficientes y modulares diseñados para manejar
                un alto volumen de transacciones sin interrupciones, con control
                total del inventario.
            </p>
        </Container>
    </section>
    <CTA />
</MainLayout>
