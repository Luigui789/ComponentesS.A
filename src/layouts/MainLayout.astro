---
import "../styles/global.css";
import Navbar from "../components/navbar/Navbar.astro";
import Footer from "../components/sections/Footer.astro";
import Analytics from "@vercel/analytics/astro";

import logo from "../assets/logo-componentes.jpeg";

interface Props {
    title: string;
    description?: string;
}

const {
    title,
    description = "Safiro: Solución tecnológica integral de Componentes S.A. Automatiza tu administración con Oracle Simphony.",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="description" content={description} />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href={logo.src} />
        <meta name="generator" content={Astro.generator} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap"
            rel="stylesheet"
        />
        <title>{title} | Componentes S.A.</title>
    </head>
    <body class="min-h-screen flex flex-col pt-20">
        <Navbar />
        <main class="flex-grow">
            <slot />
        </main>
        <Footer />
        <Analytics />
    </body>
</html>
